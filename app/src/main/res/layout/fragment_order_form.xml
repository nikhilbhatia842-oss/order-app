<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER BANNER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order Submission"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fill in all required fields to place your order"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:alpha="0.75"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- CONTENT AREA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- CARD 1: Basic Information -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@color/section_bar"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Basic Information"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Shop Name *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_store"
                        app:startIconTint="@color/primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/et_shop_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:completionThreshold="1"
                            android:dropDownHeight="wrap_content"
                            android:dropDownVerticalOffset="4dp"
                            android:hint="Enter shop name"
                            android:popupBackground="@drawable/bg_shop_suggestion_dropdown"
                            android:textColorHint="@color/text_light"
                            android:inputType="textCapWords"
                            android:maxLength="100"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Order Date *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_calendar"
                        app:startIconTint="@color/primary"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar"
                        app:endIconTint="@color/text_light"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_order_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="dd/MM/yyyy"
                            android:textColorHint="@color/text_light"
                            android:inputType="date"
                            android:focusable="false"
                            android:clickable="true"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Salesman Name *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_salesman_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter salesman name"
                            android:textColorHint="@color/text_light"
                            android:inputType="textCapWords"
                            android:maxLength="100"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 2: Order Details -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@color/section_bar"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order Details"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Number of Boxes *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_box"
                        app:startIconTint="@color/primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_number_of_boxes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter quantity"
                            android:textColorHint="@color/text_light"
                            android:inputType="number"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Specification"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:counterEnabled="true"
                        app:counterMaxLength="500"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_specification"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Optional"
                            android:textColorHint="@color/text_light"
                            android:inputType="textMultiLine"
                            android:maxLength="500"
                            android:lines="3"
                            android:gravity="top|start"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Amount per Box *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_rupee"
                        app:startIconTint="@color/primary"
                        app:prefixText="&#8377; "
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_amount_per_box"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0.00"
                            android:textColorHint="@color/text_light"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Total Amount Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFE8EFF8"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL AMOUNT"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="@color/text_medium" />

                        <TextView
                            android:id="@+id/tv_total_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8377; 0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 3: Delivery Information -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@color/section_bar"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivery Information"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Location / City *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_location"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter city or location"
                            android:textColorHint="@color/text_light"
                            android:inputType="textCapWords"
                            android:maxLength="100"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phone Number *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_medium"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_phone_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/stroke_light"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/primary"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_contacts"
                        app:endIconTint="@color/primary"
                        app:endIconContentDescription="Pick from contacts"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_phone_number"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Phone number (e.g. +91XXXXXXXXXX)"
                            android:textColorHint="@color/text_light"
                            android:inputType="phone"
                            android:maxLength="20"
                            android:textSize="15sp"
                            android:textColor="@color/text_dark" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SUBMIT BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Submit Order"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="16dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                app:icon="@drawable/ic_send"
                app:iconGravity="end"
                app:iconPadding="8dp"
                app:iconTint="@color/white"
                app:rippleColor="@color/primary_variant"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="* Required fields"
                android:textSize="12sp"
                android:textColor="@color/text_light"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
